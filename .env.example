# x402 (ai2human-style env vars)
# Receiver / payTo address on X Layer (EVM 0x… address)
# Your provided wallet: XKOadffd5c651c7de3e0df1f9b34f6ddbda52310ca9
# EVM address form:
XLAYER_X402_PAY_TO_ADDRESS=0xdffd5c651c7de3e0df1f9b34f6ddbda52310ca9

# Backward-compatible legacy name (optional)
# XLAYER_PAY_TO_ADDRESS=0xdffd5c651c7de3e0df1f9b34f6ddbda52310ca9

# Free trial mode — set to Unix timestamp (seconds) for expiry
# Leave unset for always-free in development
FREE_UNTIL=1746057600

# Optional: custom X Layer RPC
# XLAYER_RPC_URL=https://xlayer.drpc.org

# Optional (future / facilitator-settlement mode):
# If you choose server-side settlement like ai2human, set a funded facilitator key.
# XLAYER_X402_PRIVATE_KEY=0x...
