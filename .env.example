# x402 exact-settlement mode on X Layer
# SkillStore now mirrors OmniClaw's flow:
# 1) client signs transferWithAuthorization
# 2) server-side facilitator relays transferWithAuthorization onchain
# 3) invoke route returns X-PAYMENT-RESPONSE with txHash receipt

# Privy wallet login (same pattern as OmniClaw / ai2human)
NEXT_PUBLIC_PRIVY_APP_ID=cmn7kz2bc00710cl8h0fevn6h
# Optional depending on your Privy app setup:
# NEXT_PUBLIC_PRIVY_CLIENT_ID=
# NEXT_PUBLIC_PRIVY_APP_CLIENT_ID=
PRIVY_APP_ID=cmn7kz2bc00710cl8h0fevn6h
PRIVY_APP_SECRET=
#
# Receiver / payTo address on X Layer (EVM 0x... address)
XLAYER_X402_PAY_TO_ADDRESS=0xdffd5c651c7de3e0df1f9b34f6ddbda52310ca9

# Required for paid mode:
# funded facilitator private key with enough OKB gas to relay the token transfer.
XLAYER_X402_PRIVATE_KEY=0x...

# Free trial mode — set to Unix timestamp (seconds) for expiry
# Leave unset for always-free in development
FREE_UNTIL=1746057600

# Optional: custom X Layer RPC
# XLAYER_RPC_URL=https://xlayer.drpc.org

# Optional: customize token params (ai2human-style)
# XLAYER_X402_TOKEN=USDT0
# XLAYER_X402_ASSET_ADDRESS=0x779ded0c9e1022225f8e0630b35a9b54be713736
# XLAYER_X402_SYMBOL=USDT0
# XLAYER_X402_DECIMALS=6
# XLAYER_X402_TOKEN_NAME=USD₮0
# XLAYER_X402_TOKEN_VERSION=
#
# Optional: explorer base (default OKLink)
# XLAYER_EXPLORER_BASE_URL=https://www.oklink.com/xlayer

# Optional: backward-compatible legacy receiver env
# XLAYER_PAY_TO_ADDRESS=0xdffd5c651c7de3e0df1f9b34f6ddbda52310ca9
